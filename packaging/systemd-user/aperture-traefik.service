[Unit]
Description=Traefik edge proxy for Aperture
After=network.target graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
Environment=APERTURE_TRAEFIK_ENTRYPOINT_ADDRESS=:28081
Environment=APERTURE_TRAEFIK_DYNAMIC_CONFIG_PATH=%t/aperture/traefik/dynamic.yaml
EnvironmentFile=-%t/aperture/traefik/env
ExecStartPre=@runtimeShell@ -c 'install -d %t/aperture/traefik && sed -e "s|@ENTRYPOINT_ADDRESS@|$${APERTURE_TRAEFIK_ENTRYPOINT_ADDRESS}|g" -e "s|@DYNAMIC_CONFIG_PATH@|$${APERTURE_TRAEFIK_DYNAMIC_CONFIG_PATH}|g" @staticConfigTemplate@ > %t/aperture/traefik/static.yaml'
ExecStart=@traefikBin@ --configFile=%t/aperture/traefik/static.yaml
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
